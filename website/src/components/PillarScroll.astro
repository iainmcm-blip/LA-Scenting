---
const pillars = [
  { num: 'I',   title: 'Invisible Luxury',     line: 'Scent is the most sophisticated form of interior design — defining a room without occupying a single inch of floor space.' },
  { num: 'II',  title: 'Emotionally Resonant', line: 'By engaging the olfactory system we bypass logic and speak directly to the soul — serenity, focus, prestige.' },
  { num: 'III', title: 'Sustainable Alchemy',  line: 'Rare, sustainable botanicals and low-impact diffusion: an atmosphere as pure as it is evocative.' },
];
---
<section class="pillars" data-pillars>
  <div class="pillars-inner">
    {pillars.map((p) => (
      <article class="pillar">
        <span class="pillar-mark">{p.num}</span>
        <h3 class="pillar-heading">{p.title}</h3>
        <p class="pillar-copy">{p.line}</p>
      </article>
    ))}
  </div>
</section>

<script>
  import { initScroll, gsap, ScrollTrigger } from '../lib/scroll';
  import { detectTier } from '../lib/capability';

  function build() {
    const section = document.querySelector<HTMLElement>('[data-pillars]');
    if (!section) return;
    const items = Array.from(section.querySelectorAll<HTMLElement>('.pillar'));
    if (!items.length) return;

    if (detectTier() === 'reduced') {
      items.forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.position = 'relative';
      });
      return;
    }

    initScroll();

    gsap.set(items, { autoAlpha: 0, y: 40 });
    gsap.set(items[0], { autoAlpha: 1, y: 0 });

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: '+=' + (items.length * 100) + '%',
      pin: true,
      scrub: true,
      onUpdate: (self) => {
        const idx = Math.min(items.length - 1, Math.floor(self.progress * items.length));
        items.forEach((el, i) =>
          gsap.to(el, { autoAlpha: i === idx ? 1 : 0, y: i === idx ? 0 : 40, overwrite: 'auto', duration: 0.3 })
        );
      },
    });

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', build);
</script>

<style>
  .pillars {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 0 8vw;
    background: var(--cream-mid);
  }

  .pillars-inner {
    position: relative;
    width: 100%;
    max-width: 40rem;
    min-height: 16rem;
  }

  .pillar {
    position: absolute;
    inset: 0;
    display: grid;
    align-content: center;
    text-align: center;
    gap: 1rem;
  }

  .pillar-mark {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 3rem;
    color: var(--sand);
    opacity: 0.5;
  }

  .pillar-heading {
    font-family: var(--font-head);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--olive);
    line-height: 1.05;
  }

  .pillar-copy {
    font-family: var(--font-note);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.6;
    color: var(--umber);
    opacity: 0.85;
    max-width: 34rem;
    margin: 0 auto;
  }

  /* Mobile: stack them naturally, no JS pinning */
  @media (max-width: 900px) {
    .pillars {
      min-height: 0;
      padding: 10vh 8vw;
    }
    .pillars-inner {
      position: static;
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: 4rem;
    }
    .pillar {
      position: static;
    }
  }
</style>
