---
const path = Astro.url.pathname;
const isActive = (href: string) =>
  path === href || path === href + '/' || path === href + '.html' ||
  (href === '/' && (path === '/index.html' || path === '/'));
---

<nav class="main-nav" transition:persist>
  <a class="logo" href="/"><span class="la">LA</span>SCENTING</a>
  <ul class="nav-links">
    <li><a href="/" class:list={[{ active: isActive('/') }]}>Home</a></li>
    <li><a href="/about-us" class:list={[{ active: isActive('/about-us') }]}>About Us</a></li>
    <li><a href="/philosophy" class:list={[{ active: isActive('/philosophy') }]}>Philosophy</a></li>
    <li><a href="/services" class:list={[{ active: isActive('/services') }]}>Services &amp; Products</a></li>
    <li><a href="/journal" class:list={[{ active: isActive('/journal') }]}>The Journal</a></li>
    <li><a href="https://motion-sensory-site.vercel.app/index.html" target="_blank" rel="noopener">Motion Sensory</a></li>
  </ul>
  <a class="nav-cta" href="/contact">Request a Consultation</a>
  <button class="nav-hamburger" aria-label="Open menu" onclick="document.getElementById('mobileNav').classList.add('open')">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-nav-overlay" id="mobileNav" transition:persist="mobilenav">
  <button class="mobile-nav-close" onclick="document.getElementById('mobileNav').classList.remove('open')">✕</button>
  <a href="/">Home</a>
  <a href="/about-us">About Us</a>
  <a href="/philosophy">Philosophy</a>
  <a href="/services">Services &amp; Products</a>
  <a href="/journal">The Journal</a>
  <a href="https://motion-sensory-site.vercel.app/index.html" target="_blank" rel="noopener">Motion Sensory</a>
  <a href="/contact">Contact Us</a>
  <a href="/contact" class="mobile-nav-cta">Request a Consultation</a>
</div>

<script>
  function syncActive() {
    const path = location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('.main-nav .nav-links a').forEach((a) => {
      const href = a.getAttribute('href') || '';
      const isReal = href !== '#' && href.startsWith('/');
      const match = isReal && (path === href || path === href + '/' || path === href + '.html' || (href === '/' && (path === '/' || path === '/index.html')));
      a.classList.toggle('active', !!match);
    });
  }
  document.addEventListener('astro:page-load', syncActive);
</script>
