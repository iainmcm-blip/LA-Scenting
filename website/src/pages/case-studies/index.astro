---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PageHaze from '../../components/PageHaze.astro';

const studies = [
  { href: '/case-studies/changi-airport', img: '/images/case-studies/changi-aerial.jpg', num: '01', client: 'Changi Airport Singapore', sector: 'Airports & Transit Hubs', line: 'Flagship Sensory Identity Programme', featured: true },
  { href: '/case-studies/singapore-land', img: '/images/case-studies/singapore-land-lobby.jpg', num: '02', client: 'Singapore Land Group', sector: 'Commercial Real Estate', line: 'A Signature Scent That Anchors the CBD' },
  { href: '/case-studies/alila', img: '/images/case-studies/alila-pool.jpg', num: '03', client: 'Alila Hotels & Resorts', sector: 'Luxury Hospitality', line: 'Brand Permanence Across Global Destinations' },
  { href: '/case-studies/cbre', img: '/images/case-studies/cbre-office.jpg', num: '04', client: 'CBRE', sector: 'Corporate Workplace', line: 'An Atmospheric Identity for a Global Advisor' },
  { href: '/case-studies/singapore-airshow', img: '/images/vials-landscape.png', num: '05', client: 'Singapore Airshow', sector: 'Aerospace & Events', line: 'Precision Meets Sensation' },
];
const featured = studies.find((s) => s.featured);
const rest = studies.filter((s) => !s.featured);
---
<Base title="Case Studies — LA Scenting" description="Selected work from LA Scenting — scent identities for Changi Airport, Singapore Land Group, Alila Hotels & Resorts, CBRE, and the Singapore Airshow.">
  <Nav />

<style>
  .cs-card { display: block; }
  .cs-card .cs-card-img { overflow: hidden; position: relative; aspect-ratio: 16 / 11; }
  .cs-card .cs-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.2s var(--ease-out); }
  .cs-card:hover .cs-card-img img { transform: scale(1.05); }
  .cs-card-num {
    font-family: var(--font-note); font-style: italic; font-size: 1.3rem;
    color: var(--sand); margin: 20px 0 6px;
  }
  .cs-card-sector {
    font-family: var(--font-head); font-size: 0.55rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.2em; color: rgba(45,45,35,0.42);
  }
  .cs-card-client {
    font-family: var(--font-head); font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    font-weight: 700; letter-spacing: 0.01em; margin: 8px 0 6px;
    transition: color 0.3s;
  }
  .cs-card:hover .cs-card-client { color: var(--sand); }
  .cs-card-line { font-family: var(--font-note); font-style: italic; font-size: 1rem; color: var(--olive-md); }
  .cs-feature {
    display: grid; grid-template-columns: 1.25fr 1fr; gap: 56px; align-items: center;
    margin-bottom: 80px;
  }
  .cs-feature .cs-card-img { aspect-ratio: 16 / 10; }
  .cs-index-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 56px 48px; }
  @media (max-width: 860px) {
    .cs-feature { grid-template-columns: 1fr; gap: 28px; margin-bottom: 56px; }
    .cs-index-grid { grid-template-columns: 1fr; gap: 44px; }
  }
</style>

<!-- HERO -->
<section class="page-hero" style="height: 62vh; min-height: 440px;">
  <div class="page-hero-bg">
    <img decoding="async" src="/images/case-studies/atmos-detail.jpg" alt="LA Scenting selected work" style="width: 100%; height: 100%; object-fit: cover; object-position: center;">
  </div>
  <div class="page-hero-overlay"></div>
  <PageHaze />
  <div class="page-hero-content">
    <span class="hero-eyebrow">Selected Work</span>
    <h1 class="hero-title">Case Studies</h1>
  </div>
</section>

<!-- INTRO -->
<section class="section-wrap" style="background: var(--cream); padding-bottom: 24px;">
  <div class="inner" style="max-width: 820px; margin: 0 auto; text-align: center;">
    <div class="reveal">
      <span class="s-label">Proof, Not Promise</span>
      <h2 class="s-title" style="margin: 14px 0 18px;">Spaces That Leave<br>an Impression</h2>
      <p class="s-body" style="font-size: 1rem;">From the world's first airport scent identity to headquarters, hotels, and the CBD — a selection of environments where scent became part of the brand. Each began with the space, not the catalogue.</p>
    </div>
  </div>
</section>

<!-- FEATURED + GRID -->
<section class="section-wrap" style="background: var(--cream); padding-top: 32px;">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <a href={featured.href} class="cs-card cs-feature reveal">
      <div class="cs-card-img"><img loading="lazy" decoding="async" src={featured.img} alt={featured.client} /></div>
      <div>
        <span class="cs-card-sector">{featured.sector}</span>
        <div class="cs-card-num">{featured.num} / Flagship</div>
        <h3 class="cs-card-client">{featured.client}</h3>
        <p class="cs-card-line" style="margin-bottom: 20px;">{featured.line}</p>
        <span class="btn-link">View Case Study <span>→</span></span>
      </div>
    </a>

    <div class="cs-index-grid">
      {rest.map((s) => (
        <a href={s.href} class="cs-card reveal">
          <div class="cs-card-img"><img loading="lazy" decoding="async" src={s.img} alt={s.client} /></div>
          <div class="cs-card-num">{s.num}</div>
          <span class="cs-card-sector">{s.sector}</span>
          <h3 class="cs-card-client">{s.client}</h3>
          <p class="cs-card-line">{s.line}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-wrap newsletter-bg">
  <div style="max-width: 600px; margin: 0 auto; text-align: center;" class="reveal">
    <span class="s-label" style="color: rgba(201,175,128,0.5);">Work with Us</span>
    <h2 style="font-family: var(--font-head); font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--cream); margin-bottom: 16px; line-height: 1.2;">Your Space Deserves<br>a Signature.</h2>
    <p class="s-body" style="color: rgba(237,233,223,0.45); margin-bottom: 40px;">Tell us about your space and we will tell you what is possible.</p>
    <a href="/contact" class="btn btn-sand">Request a Consultation <span style="font-size:1.1em">→</span></a>
  </div>
</section>

<Footer />
<script src="/app.js" is:inline></script>
</Base>
