---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import HeroHaze from '../components/HeroHaze.astro';
import PillarScroll from '../components/PillarScroll.astro';
import ProcessTrack from '../components/ProcessTrack.astro';
import WarpImage from '../components/WarpImage.astro';
---
<Base title="LA Scenting — Scent Architecture for Extraordinary Spaces" description="LA Scenting designs immersive scent identities that shape emotion, behaviour and brand memory. Scent architecture for extraordinary spaces across Southeast Asia.">
  <Nav />

<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <video autoplay muted loop playsinline poster="/images/hero.jpg" aria-label="LA Scenting — Luxury Scent Architecture">
      <source src="/video/hero.mp4" type="video/mp4">
      <img loading="eager" fetchpriority="high" decoding="async" src="/images/hero.jpg" alt="LA Scenting — Luxury Scent Architecture">
    </video>
  </div>
  <div class="hero-overlay"></div>
  <HeroHaze />
  <div class="hero-content">
    <span class="hero-eyebrow">Scent Architecture · Est. 2018 · Southeast Asia</span>
    <h1 class="hero-title">Remember Every Space<br>You Walk Into</h1>
    <p class="hero-sub">We design immersive scent identities that shape emotion, behaviour and brand memory.</p>
    <a href="/about-us" class="btn btn-ghost">Learn More <span style="font-size:1.1em">→</span></a>
  </div>
  <div class="hero-scroll">
    <span class="hero-scroll-label">Scroll</span>
    <div class="hero-scroll-bar"></div>
  </div>
</section>

<!-- ENVIRONMENTAL IDENTITY INTRO -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;">
    <div class="reveal">
      <span class="s-label">Environmental Identity</span>
      <h2 class="s-title-lg">The Invisible Layer of Great Design</h2>
    </div>
    <div class="reveal rd1">
      <p class="s-note" style="margin-bottom: 20px;">"Scent is the last layer of architecture. It is the signature of the space."</p>
      <p class="s-body">From intimate boutiques to world-class transit hubs, we craft bespoke olfactory identities that leave an impression long after the moment has passed. LA Scenting brings the discipline of scent architecture to Southeast Asia's most extraordinary spaces.</p>
      <div style="margin-top: 32px;">
        <a href="/about-us" class="btn-link">Our Story <span>→</span></a>
      </div>
    </div>
  </div>
</section>

<!-- PILLAR SCROLL — three philosophy pillars, pinned scrub -->
<PillarScroll />

<!-- PROCESS TRACK — horizontal three-step process, pinned scrub -->
<ProcessTrack />

<!-- OUR STORIES -->
<section class="section-wrap stories-bg">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="margin-bottom: 56px;">
      <span class="s-label">Our Stories</span>
      <h2 class="s-title">Spaces That Leave<br>An Impression</h2>
    </div>

    <!-- Case Study 1 -->
    <div class="case-study reveal">
      <div class="img-box cs-img" style="aspect-ratio: 4/3; position: relative;">
        <WarpImage src="/images/changi.jpg" alt="Changi Airport Singapore" class="fill" />
        <span class="cs-tag">Hospitality</span>
      </div>
      <div>
        <p class="cs-num">01 / Case Study</p>
        <p class="cs-project">Changi Airport Singapore</p>
        <h3 class="cs-title">Flagship Sensory<br>Identity Programme</h3>
        <div class="rule"></div>
        <p class="s-body">As the official scent curator and designer for Changi Airport Singapore, we wove a signature olfactory identity throughout the terminal experience — from arrivals to departure lounges. The brief: make the world's award-winning gateway unforgettable not just to the eye, but to memory itself.</p>
        <div style="margin-top: 28px;">
          <a href="/about-us" class="btn-link">View Project <span>→</span></a>
        </div>
      </div>
    </div>

    <!-- Case Study 2 -->
    <div class="case-study reverse reveal">
      <div class="img-box cs-img" style="aspect-ratio: 4/3; position: relative;">
        <WarpImage src="/images/staircase.jpg" alt="Bespoke Hotel Scent Environment" class="fill" />
        <span class="cs-tag">Luxury Hospitality</span>
      </div>
      <div>
        <p class="cs-num">02 / Case Study</p>
        <p class="cs-project">Bespoke Hotel Collection</p>
        <h3 class="cs-title">Molecular Precision<br>at Architectural Scale</h3>
        <div class="rule"></div>
        <p class="s-body">Patented cold-air nebulization preserves the therapeutic properties of our signature oils without heat or dilution — delivering seamless HVAC connectivity or standalone sculptural units designed to disappear into high-end interiors.</p>
        <div style="margin-top: 28px;">
          <a href="/services" class="btn-link">Our Services <span>→</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DESIGNED TO SCALE -->
<section class="section-wrap scale-bg">
  <div class="scale-grid">
    <div class="scale-text reveal">
      <span class="s-label" style="color: rgba(201,175,128,0.5);">Engineered to Be Felt</span>
      <h2 class="s-title-lg">Designed to Scale.</h2>
      <p class="s-body">From intimate boutiques to global transit hubs, our diffusion technology ensures scent integrity across any architectural volume.</p>
      <a href="/services" class="btn btn-ghost" style="margin-top: 8px;">Explore Services <span style="font-size:1.1em">→</span></a>
    </div>
    <div class="reveal rd1">
      <div class="service-cards-grid">
        <div class="svc-card">
          <div class="svc-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          </div>
          <h3>Multi-Sensory Design</h3>
          <p>Bespoke scent identities crafted for your brand's unique emotional language and spatial context.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19.43 12.98c.04-.32.07-.64.07-.98 0-.34-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98 0 .33.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.58 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z"/></svg>
          </div>
          <h3>Scent Consultancy</h3>
          <p>Expert guidance from concept through to installation, ensuring every note serves your vision.</p>
        </div>
        <div class="svc-card wide">
          <div class="svc-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 6h-2.18c.07-.44.18-.86.18-1.3C18 2.57 15.43 0 12.3 0c-1.7 0-3.24.8-4.24 2.05L12 7 7.46 2.05C6.46.8 4.92 0 3.22 0 .09 0-2.48 2.57-2.48 5.7c0 .44.11.86.18 1.3H-4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h24c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 14H4V8h4.24c.89 0 1.73-.39 2.31-1.07l1.45-1.7 1.45 1.7c.58.68 1.42 1.07 2.31 1.07H20v12z"/></svg>
          </div>
          <h3>White Label &amp; Private Label</h3>
          <p>Commission exclusive scent formulations for retail, hospitality, or corporate gifting — bearing your brand alone.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- QUOTE -->
<section class="section-wrap quote-bg">
  <div class="quote-inner reveal">
    <blockquote>"Scent is the most direct path to memory. We engineer that path with architectural precision."</blockquote>
    <p class="quote-attr">LA Scenting · Philosophy</p>
  </div>
</section>

<!-- THE JOURNAL -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px;">
      <div>
        <span class="s-label">The Journal</span>
        <h2 class="s-title">Insights from the<br>Field of Scent</h2>
      </div>
      <a href="/journal" class="btn-link" style="flex-shrink: 0;">All Articles <span>→</span></a>
    </div>
    <div class="journal-grid">
      <a href="/journal" class="j-card featured reveal">
        <div class="img-box j-img" style="aspect-ratio: 4/3;">
          <img loading="lazy" decoding="async" src="/images/smoke.jpg" alt="The Psychology of Olfactory Branding">
        </div>
        <p class="j-cat">Sensory Tech · Featured</p>
        <p class="j-title">The Psychology of Olfactory Branding</p>
        <p class="s-body" style="margin-top: 8px; font-size: 0.82rem;">How scent architecture reshapes memory, emotion, and commercial engagement within high-end environments.</p>
      </a>
      <a href="/journal" class="j-card reveal rd1">
        <div class="img-box j-img">
          <img loading="lazy" decoding="async" src="/images/marble.jpg" alt="Engineering Invisible Architecture">
        </div>
        <p class="j-cat">Architecture · 12 Min Read</p>
        <p class="j-title">Engineering Invisible Architecture</p>
      </a>
      <a href="/journal" class="j-card reveal rd2">
        <div class="img-box j-img">
          <img loading="lazy" decoding="async" src="/images/dining.jpg" alt="Luxury Guest Experiences">
        </div>
        <p class="j-cat">Hospitality</p>
        <p class="j-title">The New Standard of Luxury Guest Experiences</p>
      </a>
    </div>
  </div>
</section>

<!-- NEWSLETTER -->
<section class="section-wrap newsletter-bg">
  <div class="newsletter-inner reveal">
    <h2>Stay Inspired</h2>
    <p class="nl-note">Receive our quarterly sensory reports and architectural insights.</p>
    <form class="nl-form" onsubmit="return false;">
      <input type="email" placeholder="Your email address">
      <button type="submit">Subscribe</button>
    </form>
  </div>
</section>

<!-- FOOTER -->
<footer class="main-footer">
  <div class="footer-grid">
    <div>
      <div class="footer-logo-mark"><span class="la">LA</span>SCENTING</div>
      <p class="footer-tagline">Scent architecture for extraordinary spaces.<br>Now serving Southeast Asia.</p>
    </div>
    <div>
      <span class="footer-col-label">Navigate</span>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about-us">About Us</a></li>
        <li><a href="/philosophy">Philosophy</a></li>
        <li><a href="/services">Services &amp; Products</a></li>
        <li><a href="/journal">The Journal</a></li>
      </ul>
    </div>
    <div>
      <span class="footer-col-label">Company</span>
      <ul class="footer-links">
        <li><a href="#">Motion Sensory</a></li>
        <li><a href="#">Contact Us</a></li>
        <li><a href="#">Sustainability</a></li>
      </ul>
    </div>
    <div>
      <span class="footer-col-label">Connect</span>
      <ul class="footer-links">
        <li><a href="#">Instagram</a></li>
        <li><a href="#">LinkedIn</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p class="footer-copy">© 2024 LA Scenting. All rights reserved.</p>
    <p class="footer-copy">Scent Architecture · Southeast Asia</p>
  </div>
</footer>

<script src="/app.js" is:inline></script>

<script>
  import { initScroll } from '../lib/scroll';
  document.addEventListener('astro:page-load', () => { initScroll(); });
</script>
</Base>
