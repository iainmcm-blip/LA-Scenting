---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PageHaze from '../../components/PageHaze.astro';

const collection = [
  {
    num: '01', name: 'Scented Candle', lead: 'Handpoured soy & coconut wax vessels.',
    body: 'Handpoured in soy, coconut wax, or a premium blend. Available in glass, matte, or ceramic vessels — fully branded to your identity and occasion.',
    specs: ['Available in 50g, 100g, 150g, 250g & 300g', 'Single, double, or triple wick', 'Custom label or full vessel branding', 'Fragrance developed or matched to brief'],
    moq: 'From 500 units',
  },
  {
    num: '02', name: 'Reed Diffuser', lead: 'Long-release home fragrance, glass bottles.',
    body: 'Continuous fragrance release for homes, hotels, and offices. Clean glass bottles with natural rattan or fibre reeds, and bespoke labelling across all components.',
    specs: ['Available in 100ml, 150ml & 250ml', 'Natural rattan or premium fibre reeds', 'Full label & box customisation', 'Alcohol-based or oil-based formulas'],
    moq: 'From 500 units',
  },
  {
    num: '03', name: 'Eau de Room Spritz', lead: 'Fine mist room fragrance, custom bottle.',
    body: 'A fine mist room fragrance that delivers an instant sensory signature. Developed to your brief and presented in an elegant glass bottle with custom or label branding.',
    specs: ['Available in 30ml, 50ml & 100ml', 'Fine mist pump format', 'Custom or standard bottle options', 'Carton & cap customisation available'],
    moq: 'From 500 units',
  },
  {
    num: '04', name: 'Room Spray', lead: 'Instant ambient scenting for any space.',
    body: 'Instant, on-demand ambient fragrance for any environment. Elegant misted delivery in a format that works equally well across hotels, retail, and gifting.',
    specs: ['Available in 50ml, 100ml & 200ml', 'Pump or trigger spray options', 'Alcohol-free formulations available', 'Full-wrap or front-label branding'],
    moq: 'From 500 units',
  },
  {
    num: '05', name: 'Aroma Oil', lead: 'Pure & blended oils for diffusers.',
    body: 'Pure and blended fragrance oils, formulated for ultrasonic diffusers, passive diffusion, and professional scenting equipment.',
    specs: ['Available in 10ml, 30ml & 100ml', 'Water-soluble & neat oil formats', 'Compatible with standard diffuser units', 'Custom fragrance development included'],
    moq: 'From 500 units',
  },
  {
    num: '06', name: 'Car Diffuser', lead: 'Compact vent clip or card format.',
    body: 'Scent in motion. Premium vent-clip diffusers branded with your logo — ideal for automotive brands, hotel transfers, and premium corporate gifting.',
    specs: ['Vent clip or hanging card formats', 'Custom fragrance fill', 'Full-surface print branding', 'Ready to hang or clip — no setup required'],
    moq: 'From 5,000 units',
  },
  {
    num: '07', name: 'Pillow Mist', lead: 'Calming bedtime fragrance for linen.',
    body: 'A calming bedtime ritual in a bottle. Lightly spritzed onto pillows and linens, it creates an intimate, sleep-inducing sensory experience — ideal for hospitality amenity kits and wellness brands.',
    specs: ['Available in 50ml & 100ml', 'Alcohol-free or low-alcohol formulas', 'Custom label or full bottle branding', 'Calming & sleep-focused fragrance profiles'],
    moq: 'From 500 units',
  },
  {
    num: '08', name: 'Fragrance Stone', lead: 'Ceramic diffuser, passive long-lasting scent.',
    body: 'A passive ceramic diffuser that releases fragrance gradually over weeks. Elegant, flameless, and effortless — suited to wardrobes, drawers, entryways, and hotel rooms.',
    specs: ['Ceramic or plaster disc formats', 'Custom embossed logo or printed tag', 'Ribbon, cord, or gift-box packaging', 'Fragrance developed or matched to brief'],
    moq: 'From 5,000 units',
  },
  {
    num: '09', name: '15ml Petit Spritz', lead: 'Pocket-sized personal fragrance spritz.',
    body: 'A pocket-sized personal fragrance spritz — perfect for gifting, travel retail, event favours, and branded amenity kits. Small format, maximum impact.',
    specs: ['15ml atomiser format', 'Refillable or sealed options', 'Custom label or sleeve branding', 'EDP, EDC, or room spritz fill'],
    moq: 'From 500 units',
  },
  {
    num: '10', name: 'Scented Pocket Sanitiser', lead: 'Hydrating scented hand sanitiser.',
    body: 'A hydrating, fragranced hand sanitiser in a pocket-sized format — where personal care meets sensory experience. Ideal for branded gifting, events, hospitality amenity kits, and retail.',
    specs: ['30ml pocket mist format', 'Custom fragrance development', 'Full label or sleeve branding', 'Hydrating formula with fragrance'],
    moq: 'From 5,000 units',
  },
];
---
<Base title="White Label — LA Scenting" description="LA Scenting's White Label Product Collection. Ten IFRA-compliant, retail-ready formats — fully branded to your identity. Your brand. Your product. Your story.">
  <Nav />

<style>
  /* ── The Collection — index + showcase explorer ───────────── */
  .collection {
    display: grid;
    grid-template-columns: 0.82fr 1.35fr;
    gap: 64px;
    align-items: start;
  }
  .collection-index {
    position: sticky;
    top: 104px;
    display: flex;
    flex-direction: column;
  }
  .ci-item {
    position: relative;
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 18px;
    align-items: baseline;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    border-top: 1px solid rgba(45,45,35,0.1);
    padding: 17px 8px 17px 20px;
    cursor: pointer;
    transition: padding-left 0.45s var(--ease-out);
  }
  .ci-item:last-child { border-bottom: 1px solid rgba(45,45,35,0.1); }
  .ci-item::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    transform: translateY(-50%) scaleY(0);
    transform-origin: center;
    width: 2px; height: 56%;
    background: var(--sand);
    transition: transform 0.45s var(--ease-out);
  }
  .ci-item.active::before { transform: translateY(-50%) scaleY(1); }
  .ci-item.active { padding-left: 28px; }
  .ci-num {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--sand);
    line-height: 1;
    opacity: 0.55;
    transition: opacity 0.35s var(--ease-out);
  }
  .ci-name {
    font-family: var(--font-head);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1.3;
    color: rgba(45,45,35,0.5);
    transition: color 0.35s var(--ease-out);
  }
  .ci-item:hover .ci-name { color: var(--olive); }
  .ci-item.active .ci-name { color: var(--olive); }
  .ci-item.active .ci-num { opacity: 1; }

  .collection-stage { position: relative; min-height: 440px; }
  .ci-panel { position: relative; }
  .collection.is-enhanced .ci-panel { display: none; }
  .collection.is-enhanced .ci-panel.active { display: block; }
  .ci-ghost {
    position: absolute;
    top: -28px; right: -8px;
    font-family: var(--font-note);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(5rem, 11vw, 9rem);
    color: var(--sand);
    opacity: 0.14;
    line-height: 0.8;
    pointer-events: none;
    user-select: none;
  }
  .ci-panel-name {
    font-family: var(--font-head);
    font-size: clamp(1.6rem, 3.4vw, 2.6rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.05;
    margin: 14px 0 0;
  }
  .ci-lead {
    font-family: var(--font-note);
    font-style: italic;
    font-size: clamp(1.15rem, 2.1vw, 1.55rem);
    color: var(--sand);
    margin: 14px 0 26px;
    line-height: 1.4;
  }
  .ci-desc { max-width: 560px; }
  .ci-specs {
    list-style: none;
    margin: 32px 0 0;
    border-top: 1px solid rgba(45,45,35,0.1);
  }
  .ci-specs li {
    position: relative;
    padding: 15px 0 15px 26px;
    border-bottom: 1px solid rgba(45,45,35,0.08);
    font-family: var(--font-head);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--olive-md);
  }
  .ci-specs li::before {
    content: '';
    position: absolute;
    left: 2px; top: 21px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--sand);
  }
  .ci-moq {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 32px;
    padding: 18px 28px;
    border: 1px solid rgba(201,175,128,0.5);
    background: rgba(201,175,128,0.07);
  }
  .ci-moq-label {
    font-family: var(--font-head);
    font-size: 0.52rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(45,45,35,0.45);
  }
  .ci-moq-val {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--olive);
    line-height: 1;
  }

  @media (max-width: 860px) {
    .collection { grid-template-columns: 1fr; gap: 8px; }
    .collection-index { position: static; }
    .collection-stage { min-height: 0; margin-top: 8px; }
    .ci-ghost { font-size: 5.5rem; top: -10px; }
  }
</style>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg">
    <img decoding="async" src="/images/fragrance-vials-dark.jpg" alt="LA Scenting White Label Collection" style="width: 100%; height: 100%; object-fit: cover;">
  </div>
  <div class="page-hero-overlay"></div>
  <PageHaze />
  <div class="page-hero-content">
    <span class="hero-eyebrow">White Label · Product Collection</span>
    <h1 class="hero-title">Your Vibe,<br>Bottled.</h1>
  </div>
</section>

<!-- INTRO -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: 820px; margin: 0 auto; text-align: center;">
    <div class="reveal">
      <span class="s-label">Brand Extension</span>
      <h2 class="s-title" style="margin: 14px 0 22px;">Your Brand. Your Product.<br>Your Story.</h2>
      <p class="s-body" style="font-size: 1rem;">Custom-crafted fragrances, fully white-labelled to carry your identity. The White Label Collection takes a brand's signature scent beyond the space it lives in — into retail, gifting, and the everyday objects people take home. Ten formats, developed or matched to brief, produced to IFRA standards.</p>
    </div>
  </div>
</section>

<!-- THE COLLECTION — EXPLORER -->
<section class="section-wrap" style="background: var(--cream-mid);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="max-width: 680px; margin-bottom: 56px;">
      <span class="s-label">The Collection</span>
      <h2 class="s-title" style="margin: 14px 0 16px;">Ten Formats,<br>One Identity</h2>
      <p class="s-body" style="font-size: 1rem;">Ten ways to carry your scent beyond the space — from candles to car diffusers. Choose a format to explore its sizes, branding, and order detail.</p>
    </div>

    <div class="collection reveal rd1">
      <div class="collection-index" role="tablist" aria-label="White label formats">
        {collection.map((c, i) => (
          <button class={`ci-item${i === 0 ? ' active' : ''}`} role="tab" aria-selected={i === 0 ? 'true' : 'false'} data-i={i}>
            <span class="ci-num">{c.num}</span>
            <span class="ci-name">{c.name}</span>
          </button>
        ))}
      </div>

      <div class="collection-stage">
        {collection.map((c, i) => (
          <article class={`ci-panel${i === 0 ? ' active' : ''}`} role="tabpanel" data-i={i} aria-label={c.name}>
            <span class="ci-ghost" aria-hidden="true">{c.num}</span>
            <span class="s-label">Format {c.num}</span>
            <h3 class="ci-panel-name">{c.name}</h3>
            <p class="ci-lead">{c.lead}</p>
            <p class="s-body ci-desc">{c.body}</p>
            <ul class="ci-specs">
              {c.specs.map((s) => (<li>{s}</li>))}
            </ul>
            <div class="ci-moq">
              <span class="ci-moq-label">Minimum Order</span>
              <span class="ci-moq-val">{c.moq}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- IFRA / ASSURANCE BAND -->
<section class="section-wrap scale-bg">
  <div class="inner" style="max-width: 820px; margin: 0 auto; text-align: center;">
    <div class="reveal">
      <span class="s-label" style="color: rgba(201,175,128,0.5);">Made Responsibly</span>
      <h2 class="s-title-lg" style="color: var(--cream); margin-bottom: 20px;">IFRA-Compliant,<br>Every Format</h2>
      <p class="s-body" style="color: rgba(237,233,223,0.55);">Every product in the collection is formulated and produced to International Fragrance Association standards, with safety and compliance signed off before production. Packaging, branding, and fragrance are coordinated end to end — so the product that carries your name meets the same standard as the scent in your space.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-wrap newsletter-bg">
  <div style="max-width: 640px; margin: 0 auto; text-align: center;" class="reveal">
    <span class="s-label" style="color: rgba(201,175,128,0.5);">Extend Your Brand</span>
    <h2 style="font-family: var(--font-head); font-size: clamp(1.4rem, 3vw, 2.2rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--cream); margin-bottom: 16px;">Commission Your Collection</h2>
    <p class="s-body" style="color: rgba(237,233,223,0.45); margin-bottom: 40px;">Tell us the formats you have in mind and the scent you want to carry. We will shape the range around your brand.</p>
    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
      <a href="/contact" class="btn btn-sand">Request a Consultation <span style="font-size:1.1em">→</span></a>
      <a href="/services" class="btn btn-ghost">All Services <span style="font-size:1.1em">→</span></a>
    </div>
  </div>
</section>

<Footer />

<script is:inline>
  (function () {
    function setupCollection() {
      var root = document.querySelector('.collection');
      if (!root || root.dataset.bound) return;
      root.dataset.bound = '1';
      root.classList.add('is-enhanced');
      var items = Array.prototype.slice.call(root.querySelectorAll('.ci-item'));
      var panels = Array.prototype.slice.call(root.querySelectorAll('.ci-panel'));
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var ease = 'cubic-bezier(0.22, 1, 0.36, 1)';
      function activate(i, userInitiated) {
        items.forEach(function (it, idx) {
          var on = idx === i;
          it.classList.toggle('active', on);
          it.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        panels.forEach(function (p, idx) {
          if (idx === i) {
            p.classList.add('active');
            if (!reduce) {
              p.animate(
                [{ opacity: 0, transform: 'translateY(10px)' }, { opacity: 1, transform: 'none' }],
                { duration: 460, easing: ease }
              );
            }
          } else {
            p.classList.remove('active');
          }
        });
        if (userInitiated && window.matchMedia('(max-width: 860px)').matches) {
          var stage = root.querySelector('.collection-stage');
          if (stage) stage.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
        }
      }
      items.forEach(function (it, i) {
        it.addEventListener('click', function () { activate(i, true); });
      });
      activate(0, false);
    }
    document.addEventListener('astro:page-load', setupCollection);
    if (document.readyState !== 'loading') setupCollection();
    else document.addEventListener('DOMContentLoaded', setupCollection);
  })();
</script>

<script src="/app.js" is:inline></script>
</Base>
