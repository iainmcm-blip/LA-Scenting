---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PageHaze from '../../components/PageHaze.astro';

const formats = [
  { num: '01', name: 'Scented Candle', desc: 'Handpoured soy & coconut wax vessels.' },
  { num: '02', name: 'Reed Diffuser', desc: 'Long-release home fragrance, glass bottles.' },
  { num: '03', name: 'Eau de Room Spritz', desc: 'Fine mist room fragrance, custom bottle.' },
  { num: '04', name: 'Room Spray', desc: 'Instant ambient scenting for any space.' },
  { num: '05', name: 'Aroma Oil', desc: 'Pure & blended oils for diffusers.' },
  { num: '06', name: 'Car Diffuser', desc: 'Compact vent clip or card format.' },
  { num: '07', name: 'Pillow Mist', desc: 'Calming bedtime fragrance for linen.' },
  { num: '08', name: 'Fragrance Stone', desc: 'Ceramic diffuser, passive long-lasting scent.' },
  { num: '09', name: '15ml Petit Spritz', desc: 'Pocket-sized personal fragrance spritz.' },
  { num: '10', name: 'Scented Pocket Sanitiser', desc: 'Hydrating scented hand sanitiser.' },
];

const details = [
  {
    num: '01', name: 'Scented Candle',
    body: 'Handpoured in soy, coconut wax, or a premium blend. Available in glass, matte, or ceramic vessels — fully branded to your identity and occasion.',
    features: ['Available in 50g, 100g, 150g, 250g & 300g', 'Single, double, or triple wick', 'Custom label or full vessel branding', 'Fragrance developed or matched to brief', 'Minimum order from 500 units'],
  },
  {
    num: '02', name: 'Reed Diffuser',
    body: 'Continuous fragrance release for homes, hotels, and offices. Clean glass bottles with natural rattan or fibre reeds, and bespoke labelling across all components.',
    features: ['Available in 100ml, 150ml & 250ml', 'Natural rattan or premium fibre reeds', 'Full label & box customisation', 'Alcohol-based or oil-based formulas', 'Minimum order from 500 units'],
  },
  {
    num: '03', name: 'Eau de Room Spritz',
    body: 'A fine mist room fragrance that delivers an instant sensory signature. Developed to your brief and presented in an elegant glass bottle with custom or label branding.',
    features: ['Available in 30ml, 50ml & 100ml', 'Fine mist pump format', 'Custom or standard bottle options', 'Carton & cap customisation available', 'Minimum order from 500 units'],
  },
  {
    num: '04', name: 'Room Spray',
    body: 'Instant, on-demand ambient fragrance for any environment. Elegant misted delivery in a format that works equally well across hotels, retail, and gifting.',
    features: ['Available in 50ml, 100ml & 200ml', 'Pump or trigger spray options', 'Alcohol-free formulations available', 'Full-wrap or front-label branding', 'Minimum order from 500 units'],
  },
  {
    num: '05', name: 'Aroma Oil',
    body: 'Pure and blended fragrance oils, formulated for ultrasonic diffusers, passive diffusion, and professional scenting equipment.',
    features: ['Available in 10ml, 30ml & 100ml', 'Water-soluble & neat oil formats', 'Compatible with standard diffuser units', 'Custom fragrance development included', 'Minimum order from 500 units'],
  },
  {
    num: '06', name: 'Car Diffuser',
    body: 'Scent in motion. Premium vent-clip diffusers branded with your logo — ideal for automotive brands, hotel transfers, and premium corporate gifting.',
    features: ['Vent clip or hanging card formats', 'Custom fragrance fill', 'Full-surface print branding', 'Ready to hang or clip — no setup required', 'Minimum order from 5,000 units'],
  },
  {
    num: '07', name: 'Pillow Mist',
    body: 'A calming bedtime ritual in a bottle. Lightly spritzed onto pillows and linens, it creates an intimate, sleep-inducing sensory experience — ideal for hospitality amenity kits and wellness brands.',
    features: ['Available in 50ml & 100ml', 'Alcohol-free or low-alcohol formulas', 'Custom label or full bottle branding', 'Calming & sleep-focused fragrance profiles', 'Minimum order from 500 units'],
  },
  {
    num: '08', name: 'Fragrance Stone',
    body: 'A passive ceramic diffuser that releases fragrance gradually over weeks. Elegant, flameless, and effortless — suited to wardrobes, drawers, entryways, and hotel rooms.',
    features: ['Ceramic or plaster disc formats', 'Custom embossed logo or printed tag', 'Ribbon, cord, or gift-box packaging', 'Fragrance developed or matched to brief', 'Minimum order from 5,000 units'],
  },
  {
    num: '09', name: '15ml Petit Spritz',
    body: 'A pocket-sized personal fragrance spritz — perfect for gifting, travel retail, event favours, and branded amenity kits. Small format, maximum impact.',
    features: ['15ml atomiser format', 'Refillable or sealed options', 'Custom label or sleeve branding', 'EDP, EDC, or room spritz fill', 'Minimum order from 500 units'],
  },
  {
    num: '10', name: 'Scented Pocket Sanitiser',
    body: 'A hydrating, fragranced hand sanitiser in a pocket-sized format — where personal care meets sensory experience. Ideal for branded gifting, events, hospitality amenity kits, and retail.',
    features: ['30ml pocket mist format', 'Custom fragrance development', 'Full label or sleeve branding', 'Hydrating formula with fragrance', 'Minimum order from 5,000 units'],
  },
];
---
<Base title="White Label — LA Scenting" description="LA Scenting's White Label Product Collection. Ten IFRA-compliant, retail-ready formats — fully branded to your identity. Your brand. Your product. Your story.">
  <Nav />

<style>
  .wl-card {
    background: var(--cream);
    border: 1px solid rgba(45,45,35,0.12);
    border-top: 2px solid var(--sand);
    padding: 28px 24px 30px;
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
  }
  .wl-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(45,45,35,0.1);
  }
  .wl-card-num {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 1.6rem;
    color: var(--sand);
    line-height: 1;
    margin-bottom: 14px;
    opacity: 0.7;
  }
  .wl-card-name {
    font-family: var(--font-head);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-bottom: 8px;
  }
  .wl-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .spec-row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(45,45,35,0.07);
  }
  .spec-row:last-child { border-bottom: none; }
  .spec-check {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--sand);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 2px;
  }
  .spec-check::after { content: '✓'; font-size: 0.65rem; color: var(--olive); font-weight: 700; }
  .product-label {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 4rem; font-weight: 300;
    color: var(--sand); line-height: 1;
    opacity: 0.4; margin-bottom: 8px;
  }
  @media (max-width: 900px) { .wl-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .wl-grid { grid-template-columns: 1fr; } }

  /* Format detail accordion */
  .wl-detail {
    border-top: 1px solid rgba(45,45,35,0.14);
  }
  .wl-detail:last-of-type { border-bottom: 1px solid rgba(45,45,35,0.14); }
  .wl-detail summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 26px 4px;
    transition: color 0.3s;
  }
  .wl-detail summary::-webkit-details-marker { display: none; }
  .wl-detail-num {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 1.5rem;
    color: var(--sand);
    line-height: 1;
    min-width: 38px;
  }
  .wl-detail-name {
    font-family: var(--font-head);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    font-weight: 700;
    letter-spacing: 0.01em;
    flex: 1;
  }
  .wl-detail-chev {
    position: relative;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .wl-detail-chev::before,
  .wl-detail-chev::after {
    content: '';
    position: absolute;
    background: var(--sand);
    transition: opacity 0.3s, transform 0.3s;
  }
  .wl-detail-chev::before { top: 7px; left: 0; width: 16px; height: 2px; }
  .wl-detail-chev::after { top: 0; left: 7px; width: 2px; height: 16px; }
  .wl-detail[open] .wl-detail-chev::after { opacity: 0; transform: scaleY(0); }
  .wl-detail[open] .wl-detail-name { color: var(--sand); }
  .wl-detail-body {
    padding: 0 4px 32px 62px;
    max-width: 680px;
  }
  .wl-detail-features {
    list-style: none;
    display: grid;
    gap: 10px;
  }
  .wl-detail-features li {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body, var(--font-head));
    font-size: 0.9rem;
    color: var(--olive-md);
    line-height: 1.45;
  }
  .wl-detail-features li::before {
    content: '';
    position: absolute;
    left: 0; top: 8px;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--sand);
  }
  @media (max-width: 560px) {
    .wl-detail summary { gap: 16px; }
    .wl-detail-body { padding-left: 4px; }
  }
</style>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg">
    <img decoding="async" src="/images/fragrance-vials-dark.jpg" alt="LA Scenting White Label Collection" style="width: 100%; height: 100%; object-fit: cover;">
  </div>
  <div class="page-hero-overlay"></div>
  <PageHaze />
  <div class="page-hero-content">
    <span class="hero-eyebrow">White Label · Product Collection</span>
    <h1 class="hero-title">Your Vibe,<br>Bottled.</h1>
  </div>
</section>

<!-- INTRO -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: 820px; margin: 0 auto; text-align: center;">
    <div class="reveal">
      <span class="s-label">Brand Extension</span>
      <h2 class="s-title" style="margin: 14px 0 22px;">Your Brand. Your Product.<br>Your Story.</h2>
      <p class="s-body" style="font-size: 1rem;">Custom-crafted fragrances, fully white-labelled to carry your identity. The White Label Collection takes a brand's signature scent beyond the space it lives in — into retail, gifting, and the everyday objects people take home. Ten formats, developed or matched to brief, produced to IFRA standards.</p>
    </div>
  </div>
</section>

<!-- TEN FORMATS -->
<section class="section-wrap" style="background: var(--cream-mid);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="max-width: 680px; margin-bottom: 48px;">
      <span class="s-label">Our Range</span>
      <h2 class="s-title" style="margin-top: 14px;">Ten Formats, Fully<br>White-Labelled to Carry Your Brand</h2>
    </div>
    <div class="wl-grid reveal rd1">
      {formats.map((f) => (
        <div class="wl-card">
          <div class="wl-card-num">{f.num}</div>
          <h3 class="wl-card-name">{f.name}</h3>
          <p class="s-body" style="font-size: 0.82rem;">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FORMAT DETAILS — ALL 10 -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: 920px; margin: 0 auto;">
    <div class="reveal" style="max-width: 680px; margin-bottom: 40px;">
      <span class="s-label">In Detail</span>
      <h2 class="s-title" style="margin-top: 14px;">Every Format,<br>Built to Brief</h2>
      <p class="s-body" style="font-size: 1rem; margin-top: 16px;">Select a format to see sizes, branding options, and minimum order quantities. Every product is developed or matched to your scent and produced to IFRA standards.</p>
    </div>
    <div class="reveal rd1">
      {details.map((d) => (
        <details class="wl-detail">
          <summary>
            <span class="wl-detail-num">{d.num}</span>
            <span class="wl-detail-name">{d.name}</span>
            <span class="wl-detail-chev" aria-hidden="true"></span>
          </summary>
          <div class="wl-detail-body">
            <p class="s-body" style="margin-bottom: 18px;">{d.body}</p>
            <ul class="wl-detail-features">
              {d.features.map((f) => (<li>{f}</li>))}
            </ul>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- IFRA / ASSURANCE BAND -->
<section class="section-wrap scale-bg">
  <div class="inner" style="max-width: 820px; margin: 0 auto; text-align: center;">
    <div class="reveal">
      <span class="s-label" style="color: rgba(201,175,128,0.5);">Made Responsibly</span>
      <h2 class="s-title-lg" style="color: var(--cream); margin-bottom: 20px;">IFRA-Compliant,<br>Every Format</h2>
      <p class="s-body" style="color: rgba(237,233,223,0.55);">Every product in the collection is formulated and produced to International Fragrance Association standards, with safety and compliance signed off before production. Packaging, branding, and fragrance are coordinated end to end — so the product that carries your name meets the same standard as the scent in your space.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-wrap newsletter-bg">
  <div style="max-width: 640px; margin: 0 auto; text-align: center;" class="reveal">
    <span class="s-label" style="color: rgba(201,175,128,0.5);">Extend Your Brand</span>
    <h2 style="font-family: var(--font-head); font-size: clamp(1.4rem, 3vw, 2.2rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--cream); margin-bottom: 16px;">Commission Your Collection</h2>
    <p class="s-body" style="color: rgba(237,233,223,0.45); margin-bottom: 40px;">Tell us the formats you have in mind and the scent you want to carry. We will shape the range around your brand.</p>
    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
      <a href="/contact" class="btn btn-sand">Request a Consultation <span style="font-size:1.1em">→</span></a>
      <a href="/services" class="btn btn-ghost">All Services <span style="font-size:1.1em">→</span></a>
    </div>
  </div>
</section>

<Footer />
<script src="/app.js" is:inline></script>
</Base>
