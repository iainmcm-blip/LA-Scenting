---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import PageHaze from '../components/PageHaze.astro';
---
<Base title="About Us — LA Scenting" description="LA Scenting was founded on a singular conviction: that every great space deserves a scent identity as considered as its architecture.">
  <Nav />

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg">
    <video autoplay muted loop playsinline poster="/images/incense.jpg" aria-label="LA Scenting — Our Story">
      <source src="/video/about-hero.mp4" type="video/mp4">
      <img decoding="async" src="/images/incense.jpg" alt="LA Scenting — Our Story">
    </video>
  </div>
  <div class="page-hero-overlay"></div>
  <PageHaze />
  <div class="page-hero-content">
    <span class="hero-eyebrow">Est. 2018 · Southeast Asia</span>
    <h1 class="hero-title">Our Story</h1>
  </div>
</section>

<!-- WHY WE WERE BORN -->
<section class="section-wrap" style="background: var(--cream-mid);">
  <div class="inner" style="max-width: 820px; margin: 0 auto;">
    <div class="reveal" style="text-align: center; margin-bottom: 48px;">
      <span class="s-label">Why We Were Born</span>
      <h2 class="s-title" style="margin-top: 14px;">The Gap We Were<br>Built to Close</h2>
    </div>
    <div class="reveal rd1">
      <p class="s-body" style="font-size: 1rem; margin-bottom: 22px;">Here's the problem LA Scenting was built to solve: say you install a diffusion system in your hotel. The company that sold you that machine also sells the fragrance that goes into it — and that's by design, not coincidence. The hardware is the lock-in. Once it's installed, you're choosing from their scent library, whether or not any of it actually suits your space. Nobody sat down and asked what your space needed. They just sold you what they had.</p>
      <p class="s-body" style="font-size: 1rem; margin-bottom: 22px;">LA Scenting was born to close that gap. Years spent working across a wide network of manufacturers and suppliers — and a deliberate choice to stay independent of exclusive distributorships — means every recommendation is shaped by what the space actually needs, not by what one supplier happens to sell.</p>
      <div class="rule" style="margin: 36px 0;"></div>
      <p class="s-note" style="font-size: clamp(1.15rem, 2vw, 1.5rem); line-height: 1.6; color: var(--olive);">A diffusion system is only as good as the scent it carries. A signature scent is only as good as the system delivering it consistently, two years on. We built LA Scenting to own both halves of that sentence — and everything in between.</p>
    </div>
  </div>
</section>

<!-- BRAND STORY -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;">
    <div class="reveal">
      <span class="s-label">Who We Are</span>
      <h2 class="s-title" style="margin-bottom: 28px;">A New Discipline.<br>A Singular Focus.</h2>
      <p class="s-note" style="margin-bottom: 24px;">"We believe that the most memorable spaces are not just seen — they are felt, deeply and subconsciously."</p>
      <p class="s-body">LA Scenting was founded on a singular conviction: that every great space deserves a scent identity as considered as its architecture. We are the official scent curators and designers for Changi Airport Singapore — the world's award-winning international gateway — and a trusted partner to some of the world's most discerning brands. We work at the intersection of olfactory science, spatial design, and luxury brand strategy.</p>
    </div>
    <div class="reveal rd1">
      <div class="img-box" style="aspect-ratio: 3/4; margin-bottom: 32px;">
        <img loading="lazy" decoding="async" src="/images/vials.jpg" alt="LA Scenting atelier">
      </div>
    </div>
  </div>
</section>

<!-- STATS / SCALE -->
<section class="section-wrap scale-bg">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="text-align: center; margin-bottom: 64px;">
      <span class="s-label" style="color: rgba(201,175,128,0.5);">By the Numbers</span>
      <h2 class="s-title-lg" style="color: var(--cream);">A Track Record of<br>Extraordinary Spaces</h2>
    </div>
    <div class="grid-4 reveal">
      <div style="text-align: center; padding: 32px 20px; border: 1px solid rgba(237,233,223,0.08);">
        <div class="stat-num">50+</div>
        <p class="stat-label">Spaces Transformed</p>
      </div>
      <div style="text-align: center; padding: 32px 20px; border: 1px solid rgba(237,233,223,0.08);">
        <div class="stat-num">8</div>
        <p class="stat-label">Countries Served</p>
      </div>
      <div style="text-align: center; padding: 32px 20px; border: 1px solid rgba(237,233,223,0.08);">
        <div class="stat-num">1M+</div>
        <p class="stat-label">sqm Scented</p>
      </div>
      <div style="text-align: center; padding: 32px 20px; border: 1px solid rgba(237,233,223,0.08);">
        <div class="stat-num">100%</div>
        <p class="stat-label">Bespoke Compositions</p>
      </div>
    </div>
  </div>
</section>

<!-- OUR VALUES -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="margin-bottom: 56px;">
      <span class="s-label">Brand Values</span>
      <h2 class="s-title">What We Stand For</h2>
    </div>
    <div class="grid-3">
      <div class="card-light reveal">
        <span class="tag tag-sand" style="margin-bottom: 20px;">Extra-Wide</span>
        <h3 class="card-h">Open Air Thinking</h3>
        <p class="s-body">We approach every brief without limitation — no space too large, no brief too nuanced. Breadth of vision is the foundation of every LA Scenting project.</p>
      </div>
      <div class="card-light reveal rd1">
        <span class="tag tag-olive" style="margin-bottom: 20px;">Modern</span>
        <h3 class="card-h">Rigorous Modernity</h3>
        <p class="s-body">Our compositions are informed by the latest in olfactory neuroscience and diffusion engineering — where ancient botanical knowledge meets precision technology.</p>
      </div>
      <div class="card-light reveal rd2">
        <span class="tag tag-umber" style="margin-bottom: 20px;">Luxury</span>
        <h3 class="card-h">Quiet Luxury</h3>
        <p class="s-body">True luxury announces itself only to those attuned to it. Our work is felt before it is noticed — the invisible signature of an extraordinary space.</p>
      </div>
    </div>
  </div>
</section>

<!-- FOUNDER -->
<section class="section-wrap" style="background: var(--cream-mid);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="grid-2">
      <div class="img-box reveal" style="aspect-ratio: 4/5; overflow: hidden;">
        <img loading="lazy" decoding="async" src="/images/aaliyah-portrait.jpg" alt="Aaliyah Hamdoon — Founder, LA Scenting" style="object-position: center top;">
      </div>
      <div class="reveal rd1">
        <span class="s-label">The Founder</span>
        <h2 class="s-title" style="margin-bottom: 20px;">Aaliyah Hamdoon</h2>
        <p class="s-note" style="margin-bottom: 24px;">"We create a silent logo — an olfactory identity that speaks without words and forms instant, lasting connections."</p>
        <p class="s-body" style="margin-bottom: 18px;">With 18 years of industry experience, Aaliyah brings a nuanced understanding of how scent shapes memory, behaviour and perception. An aromachologist and creative director by discipline, she designs environments and experiential events that stir the body, soul and mind into meaningful action.</p>
        <p class="s-body">Her portfolio includes serving as the official scent curator and designer for Changi Airport Singapore — the world's most awarded international gateway — as well as engagements spanning luxury hospitality, retail, real estate, and global corporate brands. From corporate to artistic, every LA Scenting project encodes a distinct perception of the brand it serves.</p>
        <div style="margin-top: 32px;">
          <a href="/contact" class="btn btn-light">Request a Consultation <span style="font-size:1.1em">→</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CLIENTS -->
<section class="section-wrap" style="background: var(--cream); padding-top: 72px; padding-bottom: 72px;">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 40px;">
      <span class="s-label reveal">Trusted By</span>
    </div>
    <div class="reveal rd1">
      <LogoMarquee />
    </div>
  </div>
</section>

<!-- STUDIO IMAGE -->
<section style="display: grid; grid-template-columns: 1fr 1fr; height: 60vh; min-height: 440px;">
  <div class="img-box reveal" style="height: 100%;">
    <img loading="lazy" decoding="async" src="/images/oil.jpg" alt="LA Scenting workshop">
  </div>
  <div style="background: var(--olive); display: flex; flex-direction: column; justify-content: center; padding: 64px;" class="reveal rd1">
    <span class="s-label" style="color: rgba(201,175,128,0.5);">Philosophy</span>
    <h2 class="s-title-lg" style="color: var(--cream); margin-bottom: 24px;">Architecture is More Than<br>What We See.</h2>
    <p class="s-body" style="color: rgba(237,233,223,0.55); margin-bottom: 32px;">It is what we feel. LA Scenting brings the final, most intimate layer of design to the world's most ambitious spaces.</p>
    <a href="/philosophy" class="btn-link sand">Our Philosophy <span>→</span></a>
  </div>
</section>

<Footer />
<script src="/app.js" is:inline></script>
</Base>
