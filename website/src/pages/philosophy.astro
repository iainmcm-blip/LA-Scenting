---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHaze from '../components/PageHaze.astro';
---
<Base title="Philosophy — LA Scenting" description="Emotional Architecture — LA Scenting's philosophy that scent is the invisible, most intimate layer of great design.">
  <Nav />

<style>
  .pillar-num {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 3.5rem;
    font-weight: 300;
    color: var(--sand);
    line-height: 1;
    margin-bottom: 16px;
    opacity: 0.6;
  }
</style>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg">
    <video autoplay muted loop playsinline poster="/images/philosophy-hero.jpg" aria-label="Philosophy — Emotional Architecture">
      <source src="/video/philosophy-hero.mp4" type="video/mp4">
      <img decoding="async" src="/images/philosophy-hero.jpg" alt="Philosophy — Emotional Architecture">
    </video>
  </div>
  <div class="page-hero-overlay"></div>
  <PageHaze />
  <div class="page-hero-content">
    <span class="hero-eyebrow">The Vision</span>
    <h1 class="hero-title">Emotional Architecture</h1>
  </div>
</section>

<!-- OPENING STATEMENT -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: 860px; margin: 0 auto; text-align: center;">
    <div class="reveal">
      <span class="s-label">The Foundation</span>
      <p class="s-note" style="font-size: clamp(1.2rem, 2.2vw, 1.7rem); line-height: 1.65; margin: 24px 0 32px;">Architecture is more than what we see; it is what we feel.</p>
      <div class="rule" style="margin: 0 auto 32px;"></div>
      <p class="s-body" style="font-size: 1rem; max-width: 640px; margin: 0 auto;">We operate at the frontier where spatial design meets olfactory science. Our philosophy is simple: every considered space deserves a scent identity as deliberate as its lighting, materiality, and proportion. This is Emotional Architecture — and it is the discipline we have spent years refining.</p>
    </div>
  </div>
</section>

<!-- THREE PILLARS -->
<section class="section-wrap scale-bg">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="text-align: center; margin-bottom: 72px;">
      <span class="s-label" style="color: rgba(201,175,128,0.5);">Core Pillars</span>
      <h2 class="s-title-lg" style="color: var(--cream);">The Art of Experience</h2>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: rgba(237,233,223,0.06);">
      <!-- Pillar 1 -->
      <div class="reveal" style="padding: 56px 40px; background: var(--olive);">
        <div class="pillar-num">I</div>
        <h3 style="font-family: var(--font-head); font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--sand); margin-bottom: 20px;">Invisible Luxury</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.5);">Scent is the most sophisticated form of interior design. It works subconsciously, defining the character of a room without occupying a single inch of floor space.</p>
        <div style="margin-top: 32px; width: 32px; height: 1px; background: rgba(201,175,128,0.3);"></div>
        <p class="s-note" style="color: rgba(201,175,128,0.45); font-size: 0.88rem; margin-top: 20px;">"The most powerful signature is the one that is sensed, not seen."</p>
      </div>

      <!-- Pillar 2 -->
      <div class="reveal rd1" style="padding: 56px 40px; background: rgba(255,255,255,0.02);">
        <div class="pillar-num">II</div>
        <h3 style="font-family: var(--font-head); font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--sand); margin-bottom: 20px;">Emotionally Resonant</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.5);">By engaging the olfactory system, we bypass logic and speak directly to the soul. Our compositions are engineered to trigger specific emotional states: serenity, focus, or prestige.</p>
        <div style="margin-top: 32px; width: 32px; height: 1px; background: rgba(201,175,128,0.3);"></div>
        <p class="s-note" style="color: rgba(201,175,128,0.45); font-size: 0.88rem; margin-top: 20px;">"Scent is the only sense with a direct line to memory and emotion."</p>
      </div>

      <!-- Pillar 3 -->
      <div class="reveal rd2" style="padding: 56px 40px; background: var(--olive);">
        <div class="pillar-num">III</div>
        <h3 style="font-family: var(--font-head); font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--sand); margin-bottom: 20px;">Sustainable Alchemy</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.5);">True luxury is responsible. We source rare, sustainable botanicals and use low-impact diffusion technology to ensure the atmosphere is as pure as it is evocative.</p>
        <div style="margin-top: 32px; width: 32px; height: 1px; background: rgba(201,175,128,0.3);"></div>
        <p class="s-note" style="color: rgba(201,175,128,0.45); font-size: 0.88rem; margin-top: 20px;">"Luxury without responsibility is merely extravagance."</p>
      </div>
    </div>
  </div>
</section>

<!-- PHILOSOPHY IN PRACTICE -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="grid-2">
      <div class="img-box reveal" style="aspect-ratio: 3/4;">
        <img loading="lazy" decoding="async" src="/images/oil.jpg" alt="LA Scenting philosophy in practice">
      </div>
      <div class="reveal rd1" style="display: flex; flex-direction: column; justify-content: center; gap: 32px;">
        <div>
          <span class="s-label">Philosophy in Practice</span>
          <h2 class="s-title" style="margin-bottom: 20px;">The Process of<br>Invisible Design</h2>
          <p class="s-body">Every LA Scenting engagement begins with listening — to the space, to the brand, to the people who will inhabit it. We map emotional journeys through architecture before we ever reach for a raw material.</p>
        </div>
        <div>
          <div style="display: flex; gap: 24px; align-items: flex-start; margin-bottom: 20px;">
            <span style="font-family: var(--font-note); font-style: italic; font-size: 1.4rem; color: var(--sand); flex-shrink: 0; line-height: 1;">01</span>
            <div>
              <h4 style="font-family: var(--font-head); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.16em; margin-bottom: 6px;">Spatial Audit</h4>
              <p class="s-body" style="font-size: 0.85rem;">Understanding the architecture, flow, dwell times, and emotional intention of every zone.</p>
            </div>
          </div>
          <div style="display: flex; gap: 24px; align-items: flex-start; margin-bottom: 20px;">
            <span style="font-family: var(--font-note); font-style: italic; font-size: 1.4rem; color: var(--sand); flex-shrink: 0; line-height: 1;">02</span>
            <div>
              <h4 style="font-family: var(--font-head); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.16em; margin-bottom: 6px;">Brand Translation</h4>
              <p class="s-body" style="font-size: 0.85rem;">Decoding your brand's visual and tonal identity into olfactory language and emotional parameters.</p>
            </div>
          </div>
          <div style="display: flex; gap: 24px; align-items: flex-start;">
            <span style="font-family: var(--font-note); font-style: italic; font-size: 1.4rem; color: var(--sand); flex-shrink: 0; line-height: 1;">03</span>
            <div>
              <h4 style="font-family: var(--font-head); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.16em; margin-bottom: 6px;">Scent Composition</h4>
              <p class="s-body" style="font-size: 0.85rem;">Bespoke formulation by our master perfumers, refined through iterative spatial testing until perfect.</p>
            </div>
          </div>
        </div>
        <div style="margin-top: 8px;">
          <a href="/services" class="btn btn-light">Our Services <span style="font-size:1.1em">→</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- QUOTE -->
<section class="section-wrap quote-bg">
  <div class="quote-inner reveal">
    <blockquote>Scent is the last layer of architecture. It is the signature of the space — and the first thing that memory recalls.</blockquote>
  </div>
</section>

<!-- CTA -->
<section class="section-wrap newsletter-bg">
  <div style="max-width: 640px; margin: 0 auto; text-align: center;" class="reveal">
    <span class="s-label" style="color: rgba(201,175,128,0.5);">Work with Us</span>
    <h2 style="font-family: var(--font-head); font-size: clamp(1.4rem, 3vw, 2.2rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--cream); margin-bottom: 16px;">Ready to Design Your Signature Scent?</h2>
    <p class="s-body" style="color: rgba(237,233,223,0.45); margin-bottom: 40px;">We work with a select number of clients each season. Tell us about your space and vision.</p>
    <a href="/contact" class="btn btn-sand">Request a Consultation <span style="font-size:1.1em">→</span></a>
  </div>
</section>

<Footer />

<script src="/app.js" is:inline></script>
</Base>
