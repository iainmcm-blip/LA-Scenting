---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHaze from '../components/PageHaze.astro';
---
<Base title="Philosophy — LA Scenting" description="Emotional Architecture — LA Scenting's philosophy that scent is the invisible, most intimate layer of great design.">
  <Nav />

<style>
  .pillar-num {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 3.5rem;
    font-weight: 300;
    color: var(--sand);
    line-height: 1;
    margin-bottom: 16px;
    opacity: 0.6;
  }
  .how-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: rgba(45,45,35,0.1);
    border: 1px solid rgba(45,45,35,0.1);
  }
  .how-step { background: var(--cream); padding: 32px 24px; display: flex; flex-direction: column; }
  .how-num { font-family: var(--font-note); font-style: italic; font-size: 2rem; color: var(--sand); line-height: 1; }
  .how-week {
    font-family: var(--font-head); font-size: 0.5rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.18em; color: rgba(45,45,35,0.4);
    margin-top: 14px;
  }
  .how-title {
    font-family: var(--font-head); font-size: 0.74rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em; margin: 6px 0 12px;
  }
  @media (max-width: 900px) {
    .how-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 520px) {
    .how-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg">
    <video autoplay muted loop playsinline poster="/images/philosophy-hero.jpg" aria-label="Philosophy — Emotional Architecture">
      <source src="/video/philosophy-hero.mp4" type="video/mp4">
      <img decoding="async" src="/images/philosophy-hero.jpg" alt="Philosophy — Emotional Architecture">
    </video>
  </div>
  <div class="page-hero-overlay"></div>
  <PageHaze />
  <div class="page-hero-content">
    <span class="hero-eyebrow">The Vision</span>
    <h1 class="hero-title">Emotional Architecture</h1>
  </div>
</section>

<!-- OPENING STATEMENT -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: 860px; margin: 0 auto; text-align: center;">
    <div class="reveal">
      <span class="s-label">The Foundation</span>
      <p class="s-note" style="font-size: clamp(1.2rem, 2.2vw, 1.7rem); line-height: 1.65; margin: 24px 0 32px;">Architecture is more than what we see; it is what we feel.</p>
      <div class="rule" style="margin: 0 auto 32px;"></div>
      <p class="s-body" style="font-size: 1rem; max-width: 640px; margin: 0 auto;">We operate at the frontier where spatial design meets olfactory science. Our philosophy is simple: every considered space deserves a scent identity as deliberate as its lighting, materiality, and proportion. This is Emotional Architecture — and it is the discipline we have spent years refining.</p>
    </div>
  </div>
</section>

<!-- THREE PILLARS -->
<section class="section-wrap scale-bg">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="text-align: center; margin-bottom: 72px;">
      <span class="s-label" style="color: rgba(201,175,128,0.5);">Core Pillars</span>
      <h2 class="s-title-lg" style="color: var(--cream);">The Art of Experience</h2>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: rgba(237,233,223,0.06);">
      <!-- Pillar 1 -->
      <div class="reveal" style="padding: 56px 40px; background: var(--olive);">
        <div class="pillar-num">I</div>
        <h3 style="font-family: var(--font-head); font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--sand); margin-bottom: 20px;">Invisible Luxury</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.5);">Scent is the most sophisticated form of interior design. It works subconsciously, defining the character of a room without occupying a single inch of floor space.</p>
        <div style="margin-top: 32px; width: 32px; height: 1px; background: rgba(201,175,128,0.3);"></div>
        <p class="s-note" style="color: rgba(201,175,128,0.45); font-size: 0.88rem; margin-top: 20px;">"The most powerful signature is the one that is sensed, not seen."</p>
      </div>

      <!-- Pillar 2 -->
      <div class="reveal rd1" style="padding: 56px 40px; background: rgba(255,255,255,0.02);">
        <div class="pillar-num">II</div>
        <h3 style="font-family: var(--font-head); font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--sand); margin-bottom: 20px;">Emotionally Resonant</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.5);">By engaging the olfactory system, we bypass logic and speak directly to the soul. Our compositions are engineered to trigger specific emotional states: serenity, focus, or prestige.</p>
        <div style="margin-top: 32px; width: 32px; height: 1px; background: rgba(201,175,128,0.3);"></div>
        <p class="s-note" style="color: rgba(201,175,128,0.45); font-size: 0.88rem; margin-top: 20px;">"Scent is the only sense with a direct line to memory and emotion."</p>
      </div>

      <!-- Pillar 3 -->
      <div class="reveal rd2" style="padding: 56px 40px; background: var(--olive);">
        <div class="pillar-num">III</div>
        <h3 style="font-family: var(--font-head); font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--sand); margin-bottom: 20px;">Sustainable Alchemy</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.5);">True luxury is responsible. We source rare, sustainable botanicals and use low-impact diffusion technology to ensure the atmosphere is as pure as it is evocative.</p>
        <div style="margin-top: 32px; width: 32px; height: 1px; background: rgba(201,175,128,0.3);"></div>
        <p class="s-note" style="color: rgba(201,175,128,0.45); font-size: 0.88rem; margin-top: 20px;">"Luxury without responsibility is merely extravagance."</p>
      </div>
    </div>
  </div>
</section>

<!-- THE SPACE DECIDES THE FORMULA -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="max-width: 720px; margin: 0 auto 64px; text-align: center;">
      <span class="s-label">The Method</span>
      <h2 class="s-title" style="margin: 14px 0 20px;">The Space Decides<br>the Formula</h2>
      <p class="s-body" style="font-size: 1rem;">The fragrance is never the brief. The space is. Three variables set the accord before a single note is chosen.</p>
    </div>
    <div class="grid-3">
      <div class="reveal" style="padding: 40px 32px; border: 1px solid rgba(45,45,35,0.1);">
        <div style="font-family: var(--font-note); font-style: italic; font-size: 2.4rem; color: var(--sand); line-height: 1; margin-bottom: 20px;">01</div>
        <h3 style="font-family: var(--font-head); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 14px;">Volume &amp; Ceiling Height</h3>
        <p class="s-body" style="font-size: 0.88rem;">Dispersal changes with architecture. A high-ceilinged atrium needs a different concentration and HVAC integration than a boutique fitting room. The formula begins with cubic metres, not preference.</p>
      </div>
      <div class="reveal rd1" style="padding: 40px 32px; border: 1px solid rgba(45,45,35,0.1);">
        <div style="font-family: var(--font-note); font-style: italic; font-size: 2.4rem; color: var(--sand); line-height: 1; margin-bottom: 20px;">02</div>
        <h3 style="font-family: var(--font-head); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 14px;">Foot Traffic</h3>
        <p class="s-body" style="font-size: 0.88rem;">Higher turnover dilutes scent faster. A transit space serving 3,000 passengers an hour demands continuous-feed systems with real-time intensity calibration. Retail with an 8-minute dwell time needs another approach entirely.</p>
      </div>
      <div class="reveal rd2" style="padding: 40px 32px; border: 1px solid rgba(45,45,35,0.1);">
        <div style="font-family: var(--font-note); font-style: italic; font-size: 2.4rem; color: var(--sand); line-height: 1; margin-bottom: 20px;">03</div>
        <h3 style="font-family: var(--font-head); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 14px;">Brand Intention</h3>
        <p class="s-body" style="font-size: 0.88rem;">The brief starts with the feeling. What emotion should arrive 30 seconds before a guest sees your brand? Calm authority. Warmth. Anticipation. The accord is designed backwards from that answer.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW WE WORK — 5-STEP PROCESS -->
<section class="section-wrap" style="background: var(--cream-mid);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="max-width: 680px; margin-bottom: 56px;">
      <span class="s-label">Philosophy in Practice</span>
      <h2 class="s-title" style="margin: 14px 0 18px;">How We Work</h2>
      <p class="s-body" style="font-size: 1rem;">Every engagement begins with listening — to the space, the brand, and the people who move through it. From there, a defined sequence carries a project from first brief to a scent still performing years on.</p>
    </div>
    <div class="how-grid reveal rd1">
      <div class="how-step">
        <span class="how-num">01</span>
        <span class="how-week">Week 1</span>
        <h4 class="how-title">Discovery Brief</h4>
        <p class="s-body" style="font-size: 0.82rem;">Consultation on space, brand, audience, and intent. We map the emotional journey before we discuss fragrance.</p>
      </div>
      <div class="how-step">
        <span class="how-num">02</span>
        <span class="how-week">Weeks 1–2</span>
        <h4 class="how-title">Space Assessment</h4>
        <p class="s-body" style="font-size: 0.82rem;">Technical review of architecture, airflow, footfall, and diffusion infrastructure. Systems are specified at this stage.</p>
      </div>
      <div class="how-step">
        <span class="how-num">03</span>
        <span class="how-week">Weeks 3–6</span>
        <h4 class="how-title">Accord Development</h4>
        <p class="s-body" style="font-size: 0.82rem;">The brief translated into fragrance. Multiple rounds of sampling and sensory review until the accord is approved.</p>
      </div>
      <div class="how-step">
        <span class="how-num">04</span>
        <span class="how-week">Weeks 6–8</span>
        <h4 class="how-title">Installation & Calibration</h4>
        <p class="s-body" style="font-size: 0.82rem;">System installation and live calibration. Intensity, schedule, and zoning refined in the actual environment.</p>
      </div>
      <div class="how-step">
        <span class="how-num">05</span>
        <span class="how-week">Ongoing</span>
        <h4 class="how-title">Ongoing Service</h4>
        <p class="s-body" style="font-size: 0.82rem;">Scheduled maintenance, fragrance supply, and performance reviews. Retainer or per-service models available.</p>
      </div>
    </div>
    <div class="reveal" style="margin-top: 48px;">
      <a href="/services" class="btn btn-light">Our Services <span style="font-size:1.1em">→</span></a>
    </div>
  </div>
</section>

<!-- QUOTE -->
<section class="section-wrap quote-bg">
  <div class="quote-inner reveal">
    <blockquote>Scent is the last layer of architecture. It is the signature of the space — and the first thing that memory recalls.</blockquote>
  </div>
</section>

<!-- CTA -->
<section class="section-wrap newsletter-bg">
  <div style="max-width: 640px; margin: 0 auto; text-align: center;" class="reveal">
    <span class="s-label" style="color: rgba(201,175,128,0.5);">Work with Us</span>
    <h2 style="font-family: var(--font-head); font-size: clamp(1.4rem, 3vw, 2.2rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--cream); margin-bottom: 16px;">Ready to Design Your Signature Scent?</h2>
    <p class="s-body" style="color: rgba(237,233,223,0.45); margin-bottom: 40px;">We work with a select number of clients each season. Tell us about your space and vision.</p>
    <a href="/contact" class="btn btn-sand">Request a Consultation <span style="font-size:1.1em">→</span></a>
  </div>
</section>

<Footer />

<script src="/app.js" is:inline></script>
</Base>
