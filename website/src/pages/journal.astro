---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="The Journal — LA Scenting" description="Insights on scent architecture, olfactory branding, hospitality design, and the science of sensory experience from LA Scenting.">
  <Nav />

<style>
  .filter-bar {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }
  .filter-btn {
    font-family: var(--font-head);
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    padding: 8px 18px;
    border: 1px solid rgba(45,45,35,0.15);
    color: rgba(45,45,35,0.45);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s;
  }
  .filter-btn.active,
  .filter-btn:hover {
    background: var(--olive);
    color: var(--cream);
    border-color: var(--olive);
  }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px 28px;
  }
  .article-card {
    display: block;
    cursor: pointer;
  }
  .article-card .ac-img {
    aspect-ratio: 16/10;
    overflow: hidden;
    margin-bottom: 18px;
  }
  .article-card .ac-img img {
    transition: transform 1.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .article-card:hover .ac-img img {
    transform: scale(1.04);
  }
  .ac-cat {
    font-family: var(--font-head);
    font-size: 0.5rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--sand);
    margin-bottom: 8px;
  }
  .ac-title {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.4;
    color: var(--olive);
    margin-bottom: 10px;
    transition: color 0.3s;
  }
  .article-card:hover .ac-title { color: var(--umber); }
  .ac-excerpt {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(45,45,35,0.55);
  }
  .further-reading {
    border-top: 1px solid rgba(45,45,35,0.08);
    padding-top: 48px;
    margin-top: 48px;
  }
  .fr-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 20px 0;
    border-bottom: 1px solid rgba(45,45,35,0.06);
  }
  .fr-num {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--sand);
    flex-shrink: 0;
    width: 24px;
    opacity: 0.6;
  }
  @media (max-width: 1100px) {
    .article-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .article-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- FEATURED STORY -->
<section style="padding-top: var(--nav-h); background: var(--olive);">
  <div style="display: grid; grid-template-columns: 1fr 1fr; min-height: 70vh;">
    <div class="img-box" style="min-height: 480px;">
      <img loading="eager" fetchpriority="high" decoding="async" src="/images/smoke.jpg" alt="The Psychology of Olfactory Branding">
    </div>
    <div style="display: flex; flex-direction: column; justify-content: flex-end; padding: 72px 64px;">
      <span class="s-label" style="color: rgba(201,175,128,0.5); margin-bottom: 8px;">Featured Story</span>
      <p style="font-family: var(--font-note); font-style: italic; font-size: 0.9rem; color: rgba(201,175,128,0.5); margin-bottom: 16px;">Philosophy and Science · Long Read</p>
      <h1 style="font-family: var(--font-head); font-size: clamp(1.6rem, 3vw, 2.6rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--cream); line-height: 1.1; margin-bottom: 20px;">The Psychology of Olfactory Branding</h1>
      <p class="s-body" style="color: rgba(237,233,223,0.5); max-width: 400px; margin-bottom: 32px;">How scent architecture reshapes memory, emotion, and commercial engagement within high-end environments.</p>
      <a href="#" class="btn-link sand">Read Article <span>→</span></a>
    </div>
  </div>
</section>

<!-- ALL INSIGHTS -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="margin-bottom: 40px;">
      <span class="s-label">All Insights</span>
      <h2 class="s-title">From the Field</h2>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar reveal">
      <button class="filter-btn active" onclick="filterArticles(this, 'all')">All Insights</button>
      <button class="filter-btn" onclick="filterArticles(this, 'philosophy')">Philosophy and Science</button>
      <button class="filter-btn" onclick="filterArticles(this, 'inside')">Inside LA Scenting</button>
      <button class="filter-btn" onclick="filterArticles(this, 'projects')">Projects</button>
      <button class="filter-btn" onclick="filterArticles(this, 'workshops')">Workshops &amp; Craft</button>
    </div>

    <!-- Article grid -->
    <div class="article-grid">
      <a class="article-card reveal" href="#" data-cat="philosophy">
        <div class="ac-img img-box">
          <img loading="lazy" decoding="async" src="/images/marble.jpg" alt="Engineering Invisible Architecture">
        </div>
        <p class="ac-cat">Philosophy and Science · 12 Min Read</p>
        <p class="ac-title">Engineering Invisible Architecture</p>
        <p class="ac-excerpt">The integration of HVAC-native diffusion systems into contemporary skyscrapers requires a delicate balance between mechanical precision and sensory poetry.</p>
      </a>

      <a class="article-card reveal rd1" href="#" data-cat="projects">
        <div class="ac-img img-box">
          <img loading="lazy" decoding="async" src="/images/dining.jpg" alt="Luxury Guest Experiences">
        </div>
        <p class="ac-cat">Projects</p>
        <p class="ac-title">The New Standard of Luxury Guest Experiences</p>
        <p class="ac-excerpt">How the world's leading hotel brands are using olfactory identity to command emotional loyalty — and why the future of luxury is largely invisible.</p>
      </a>

      <a class="article-card reveal rd2" href="#" data-cat="inside">
        <div class="ac-img img-box">
          <img loading="lazy" decoding="async" src="/images/incense.jpg" alt="Scent as Sculpture">
        </div>
        <p class="ac-cat">Inside LA Scenting</p>
        <p class="ac-title">Scent as Sculpture: The Aesthetics of Diffusion</p>
        <p class="ac-excerpt">When the diffuser is itself a work of art, the distinction between hardware and sculpture dissolves entirely. A conversation with our design team.</p>
      </a>

      <a class="article-card reveal" href="#" data-cat="projects">
        <div class="ac-img img-box">
          <img loading="lazy" decoding="async" src="/images/living.jpg" alt="Residential Olfactive Curation">
        </div>
        <p class="ac-cat">Projects</p>
        <p class="ac-title">Residential Olfactive Curation</p>
        <p class="ac-excerpt">Designing private sanctuaries through personalised scent layering and atmospheric zones — where the home becomes a sensory retreat.</p>
      </a>

      <a class="article-card reveal rd1" href="#" data-cat="philosophy">
        <div class="ac-img img-box">
          <img loading="lazy" decoding="async" src="/images/vials.jpg" alt="The Science of Diffusion">
        </div>
        <p class="ac-cat">Philosophy and Science</p>
        <p class="ac-title">The Science of Diffusion</p>
        <p class="ac-excerpt">Understanding cold-air nebulisation and its impact on essential oil integrity — why temperature matters at the molecular level.</p>
      </a>

      <a class="article-card reveal rd2" href="#" data-cat="workshops">
        <div class="ac-img img-box">
          <img loading="lazy" decoding="async" src="/images/lavender.jpg" alt="Botanical Sourcing Ethics">
        </div>
        <p class="ac-cat">Workshops &amp; Craft</p>
        <p class="ac-title">Botanical Sourcing Ethics</p>
        <p class="ac-excerpt">A journey from the heart of the Grasse region to our global partner estates — and what responsible luxury means when it comes to raw materials.</p>
      </a>
    </div>

    <!-- Further Reading -->
    <div class="further-reading reveal">
      <span class="s-label" style="margin-bottom: 24px;">Further Reading</span>
      <div class="fr-item">
        <span class="fr-num">i</span>
        <div>
          <p style="font-family: var(--font-head); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 4px;">Scent as the Unseen Fabric of Hospitality</p>
          <p class="s-body" style="font-size: 0.8rem;">How scent weaves through the guest journey from arrival to memory.</p>
        </div>
        <a href="#" class="btn-link" style="margin-left: auto; flex-shrink: 0; font-size: 0.52rem;">Read →</a>
      </div>
      <div class="fr-item">
        <span class="fr-num">ii</span>
        <div>
          <p style="font-family: var(--font-head); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 4px;">Curating the Summer Note: Bergamot and Slate</p>
          <p class="s-body" style="font-size: 0.8rem;">Inside our seasonal composition process with our lead perfumer.</p>
        </div>
        <a href="#" class="btn-link" style="margin-left: auto; flex-shrink: 0; font-size: 0.52rem;">Read →</a>
      </div>
      <div class="fr-item">
        <span class="fr-num">iii</span>
        <div>
          <p style="font-family: var(--font-head); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 4px;">The Future of AI-Driven Ambient Scents</p>
          <p class="s-body" style="font-size: 0.8rem;">Exploring how machine learning is beginning to inform adaptive olfactory environments.</p>
        </div>
        <a href="#" class="btn-link" style="margin-left: auto; flex-shrink: 0; font-size: 0.52rem;">Read →</a>
      </div>
      <div class="fr-item">
        <span class="fr-num">iv</span>
        <div>
          <p style="font-family: var(--font-head); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 4px;">Designing Tranquility for the Modern Workspace</p>
          <p class="s-body" style="font-size: 0.8rem;">How post-pandemic office design is embracing scent as a wellbeing tool.</p>
        </div>
        <a href="#" class="btn-link" style="margin-left: auto; flex-shrink: 0; font-size: 0.52rem;">Read →</a>
      </div>
    </div>
  </div>
</section>

<!-- NEWSLETTER -->
<section class="section-wrap newsletter-bg">
  <div class="newsletter-inner reveal">
    <h2>Stay Inspired</h2>
    <p class="nl-note">Receive our quarterly sensory reports and architectural insights.</p>
    <form class="nl-form" onsubmit="return false;">
      <input type="email" placeholder="Your email address">
      <button type="submit">Subscribe</button>
    </form>
  </div>
</section>

<Footer />

<script is:inline>
  function filterArticles(btn, cat) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.article-card').forEach(card => {
      if (cat === 'all' || card.dataset.cat === cat) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>
<script src="/app.js" is:inline></script>
</Base>
