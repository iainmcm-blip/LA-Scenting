---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHaze from '../components/PageHaze.astro';

const pillars = [
  {
    num: '01',
    name: 'Fragrance Consultancy',
    category: 'Creative & Brand',
    body: 'The starting point for every project: understanding what a space is trying to say before any scent is chosen. Brand and spatial discovery, scent direction development, and the right olfactory profile for the space’s purpose, audience, and identity — not a pre-existing scent library.',
    audience: 'For CMOs, brand and creative directors shaping how a space should feel.',
    engagement: 'Project retainer · typically a 3–6 month engagement',
    link: null,
  },
  {
    num: '02',
    name: 'Scent Architecture',
    category: 'Technical Advisory',
    body: 'Translating a chosen scent direction into a deployable plan across a physical space. We map airflow, zoning, ceiling height, materials, and traffic patterns to determine where and how scent should be experienced — so the fragrance behaves consistently across every area rather than competing with the environment.',
    audience: 'For facilities managers, M&E consultants, and architects planning the build.',
    engagement: 'Per-engagement advisory',
    link: null,
  },
  {
    num: '03',
    name: 'Technical Mapping & Execution',
    category: 'Delivery & QC',
    body: 'The hands-on technical layer: selecting and specifying the right diffusion hardware across our four tiers, calculating coverage and concentration, and overseeing installation. This is where “the space decides the formula” becomes physical — the system is chosen to match the space, not the other way around.',
    audience: 'For project managers and site teams bringing the system to life.',
    engagement: 'Milestone-based · supervised installation',
    link: { href: '#hardware', label: 'See the hardware' },
  },
  {
    num: '04',
    name: 'Project Management',
    category: 'Ongoing Retainer',
    body: 'Ongoing oversight once the system is live — calibration, scent rotation, maintenance scheduling, and quality consistency over time. A signature scent is only as good as its delivery two years on; we manage that relationship for the life of the installation, not just the install date.',
    audience: 'For operations and brand teams holding consistency across properties.',
    engagement: 'Monthly retainer · annual partnership',
    link: null,
  },
  {
    num: '05',
    name: 'White Label',
    category: 'Product & Brand Extension',
    body: 'Our IFRA-compliant product range — ten retail-ready formats for brands who want their signature scent extended into physical, gifting, or retail products. A brand’s olfactory identity, living beyond the space itself.',
    audience: 'For retail, hospitality, and procurement leads extending the brand.',
    engagement: 'Per-format production · from 500 units',
    link: { href: '/services/white-label', label: 'Explore White Label' },
  },
  {
    num: '06',
    name: 'Workshops & Events',
    category: 'Experience & Education',
    body: 'Hands-on sessions for brands, teams, and individuals who want to understand scent design directly — from fragrance fundamentals to brand-specific development exercises. We also deploy Fragrance Activations: a mobile scent bar for live, in-person fragrance mixology at events.',
    audience: 'For HR, L&D, events, and marketing teams creating live experiences.',
    engagement: 'Per session · group rates available',
    link: { href: '/services/workshops', label: 'Explore Workshops & Events' },
  },
];
---
<Base title="Services &amp; Products — LA Scenting" description="Six advisory pillars — from fragrance consultancy and scent architecture to execution, ongoing management, white label products, and workshops. LA Scenting owns the whole scent ecosystem.">
  <Nav />

<style>
  .spec-row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(45,45,35,0.07);
  }
  .spec-row:last-child { border-bottom: none; }
  .spec-check {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--sand);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .spec-check::after {
    content: '✓';
    font-size: 0.65rem;
    color: var(--olive);
    font-weight: 700;
  }
  .product-label {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 4rem;
    font-weight: 300;
    color: var(--sand);
    line-height: 1;
    opacity: 0.4;
    margin-bottom: 8px;
  }
  .tech-icon {
    width: 48px;
    height: 48px;
    background: rgba(201,175,128,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    font-family: var(--font-note);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--sand);
  }
  .method-intro {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }
  .editorial-break {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
  }
  /* Six advisory pillars */
  .pillar-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    padding: 48px 0;
    border-top: 1px solid rgba(45,45,35,0.12);
    align-items: start;
  }
  .pillar-row:last-child { border-bottom: 1px solid rgba(45,45,35,0.12); }
  .pillar-index {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 3.6rem;
    font-weight: 300;
    color: var(--sand);
    line-height: 0.9;
  }
  .pillar-cat {
    font-family: var(--font-head);
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(45,45,35,0.4);
    margin-top: 12px;
  }
  .pillar-name {
    font-family: var(--font-head);
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    font-weight: 700;
    letter-spacing: 0.01em;
    margin-bottom: 16px;
  }
  .pillar-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 32px;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid rgba(45,45,35,0.08);
  }
  .pillar-meta-item { display: flex; flex-direction: column; gap: 3px; max-width: 340px; }
  .pillar-meta-label {
    font-family: var(--font-head);
    font-size: 0.52rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(45,45,35,0.38);
  }
  .pillar-meta-val {
    font-family: var(--font-note);
    font-style: italic;
    font-size: 0.98rem;
    color: var(--olive-md);
    line-height: 1.35;
  }
  @media (max-width: 768px) {
    .editorial-break { grid-template-columns: 1fr; }
    .pillar-row { grid-template-columns: 1fr; gap: 16px; padding: 36px 0; }
    .pillar-index { font-size: 2.8rem; }
  }
</style>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg">
    <video autoplay muted loop playsinline poster="/images/services-hero.jpg" aria-label="LA Scenting — The Method">
      <source src="/video/services-hero.mp4" type="video/mp4">
      <img decoding="async" src="/images/services-hero.jpg" alt="LA Scenting — The Method">
    </video>
  </div>
  <div class="page-hero-overlay"></div>
  <PageHaze />
  <div class="page-hero-content">
    <span class="hero-eyebrow">Services &amp; Products</span>
    <h1 class="hero-title">The Scenting<br>Architecture</h1>
  </div>
</section>

<!-- THE METHOD INTRO -->
<section class="section-wrap scale-bg">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal method-intro" style="margin-bottom: 64px;">
      <span class="s-label" style="color: rgba(201,175,128,0.5);">The Method</span>
      <h2 class="s-title-lg" style="color: var(--cream);">Strategy, Technology,<br>and Execution. Under One Roof.</h2>
      <p class="s-body" style="color: rgba(237,233,223,0.55); margin-top: 20px; max-width: 580px; margin-left: auto; margin-right: auto;">Most of the industry sells you a machine, then sells you the scent to fill it. We built the opposite. Six connected pillars take a space from first brief to ongoing care — a single discipline, owned end to end, with no supplier deciding the answer for you.</p>
    </div>
    <div class="grid-3 reveal">
      <div style="text-align: center; padding: 36px 24px; border: 1px solid rgba(237,233,223,0.07);">
        <p style="font-family: var(--font-note); font-style: italic; font-size: 1rem; color: rgba(201,175,128,0.6); margin-bottom: 12px;">Integration</p>
        <h3 style="font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--cream); margin-bottom: 8px;">HVAC &amp; Standalone</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.4); font-size: 0.82rem;">Seamlessly connects to existing air handling units — or deploys as a discreet sculptural diffuser. Your architecture dictates the approach; our systems adapt without compromise.</p>
      </div>
      <div style="text-align: center; padding: 36px 24px; border: 1px solid rgba(237,233,223,0.07);">
        <p style="font-family: var(--font-note); font-style: italic; font-size: 1rem; color: rgba(201,175,128,0.6); margin-bottom: 12px;">Precision</p>
        <h3 style="font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--cream); margin-bottom: 8px;">0.1 Micrometre Mist</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.4); font-size: 0.82rem;">Cold-air nebulization at 0.1 micrometre preserves the therapeutic and aromatic integrity of every molecular note — a scent that performs exactly as formulated, every hour of every day.</p>
      </div>
      <div style="text-align: center; padding: 36px 24px; border: 1px solid rgba(237,233,223,0.07);">
        <p style="font-family: var(--font-note); font-style: italic; font-size: 1rem; color: rgba(201,175,128,0.6); margin-bottom: 12px;">Intelligence</p>
        <h3 style="font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--cream); margin-bottom: 8px;">IoT Cloud Control</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.4); font-size: 0.82rem;">Manage intensity, scheduling, and diagnostics across a single property or an entire global estate from one dashboard — giving operators real-time precision without the complexity.</p>
      </div>
    </div>
  </div>
</section>

<!-- SIX ADVISORY PILLARS -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="max-width: 720px; margin-bottom: 24px;">
      <span class="s-label">The Advisory Model</span>
      <h2 class="s-title" style="margin: 14px 0 18px;">Six Pillars,<br>One Ecosystem</h2>
      <p class="s-body" style="font-size: 1rem;">Engage one pillar or the full sequence. Each stands alone; together they cover everything from the first creative brief to the scent still performing two years on.</p>
    </div>
    {pillars.map((p) => (
      <div class="pillar-row reveal" id={p.num === '03' ? 'pillar-03' : undefined}>
        <div>
          <div class="pillar-index">{p.num}</div>
          <p class="pillar-cat">{p.category}</p>
        </div>
        <div>
          <h3 class="pillar-name">{p.name}</h3>
          <p class="s-body" style="font-size: 0.95rem;">{p.body}</p>
          <div class="pillar-meta">
            <div class="pillar-meta-item">
              <span class="pillar-meta-label">Who it's for</span>
              <span class="pillar-meta-val">{p.audience}</span>
            </div>
            <div class="pillar-meta-item">
              <span class="pillar-meta-label">Engagement</span>
              <span class="pillar-meta-val">{p.engagement}</span>
            </div>
          </div>
          {p.link && (
            <div style="margin-top: 24px;">
              <a href={p.link.href} class="btn-link">{p.link.label} <span>→</span></a>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<!-- HARDWARE — PILLAR 03 DETAIL -->
<section class="section-wrap" style="background: var(--cream-mid);" id="hardware">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="max-width: 680px; margin-bottom: 8px;">
      <span class="s-label">Technical Mapping &amp; Execution</span>
      <h2 class="s-title" style="margin: 14px 0 18px;">The Hardware Tiers</h2>
      <p class="s-body" style="font-size: 1rem;">Pillar 03 made physical. The diffusion system is specified to the space — its volume, traffic, and intention — never sold ahead of it. Two of our signature systems below.</p>
    </div>
  </div>
</section>

<!-- MODEL 01 -->
<section class="section-wrap" style="background: var(--cream);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;">
      <div class="reveal">
        <div class="product-label">01</div>
        <span class="s-label">Scent Medium</span>
        <h2 class="s-title" style="margin-bottom: 8px;">For Signature Spaces<br>That Demand More</h2>
        <p class="s-body" style="margin-bottom: 28px;">Hotels, airport terminals, commercial towers, luxury retail flagships — spaces where scent must perform invisibly across an entire architecture. Scent Medium integrates directly with your HVAC system, distributing a uniform olfactory identity to every zone without a single visible unit.</p>
        <div>
          <div class="spec-row">
            <div class="spec-check"></div>
            <p class="s-body">Covers up to 1,000 sqm — seamless multi-zone distribution via HVAC integration, no visible hardware</p>
          </div>
          <div class="spec-row">
            <div class="spec-check"></div>
            <p class="s-body">Precision scheduling via the LA Scenting app — intensity, zone mapping, and daily rhythms programmed to your brief</p>
          </div>
          <div class="spec-row">
            <div class="spec-check"></div>
            <p class="s-body">Minimalist powder-coated aluminium finish — engineered to disappear into the architecture it serves</p>
          </div>
          <div class="spec-row">
            <div class="spec-check"></div>
            <p class="s-body">Zero heat, zero ozone — diffusing 100% essential oil compounds for healthier, purer interiors</p>
          </div>
        </div>
        <div style="margin-top: 36px; display: flex; gap: 16px; flex-wrap: wrap;">
          <a href="/contact" class="btn btn-dark">Enquire Now <span style="font-size:1.1em">→</span></a>
          <a href="/contact" class="btn btn-light">Request Brochure</a>
        </div>
      </div>
      <div class="img-box reveal rd1" style="aspect-ratio: 3/4;">
        <img loading="lazy" decoding="async" src="/images/diffuser.jpg" alt="Scent Medium — LA Scenting Model 01">
      </div>
    </div>
  </div>
</section>

<!-- EDITORIAL BREAK — amber bottles -->
<div class="editorial-break">
  <div class="img-box" style="min-height: 480px;">
    <img loading="lazy" decoding="async" src="/images/amber-bottles-stacked.jpg" alt="LA Scenting — the art of fragrance composition">
  </div>
  <div style="background: var(--olive); display: flex; flex-direction: column; justify-content: center; padding: 72px 64px;">
    <span class="s-label" style="color: rgba(201,175,128,0.5);">The Accord</span>
    <h2 class="s-title-lg" style="color: var(--cream); margin-bottom: 24px;">The Formula Is Never<br>the Starting Point.</h2>
    <p class="s-body" style="color: rgba(237,233,223,0.55); margin-bottom: 0;">We design backwards from an emotion. The space is the brief. The brand is the language. The accord — developed by our master perfumers through iterative spatial testing — is the answer. Raw materials are selected for purity, longevity, and environmental responsibility.</p>
  </div>
</div>

<!-- MODEL 02 -->
<section class="section-wrap" style="background: var(--cream-mid);">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;">
      <div class="img-box reveal" style="aspect-ratio: 3/4;">
        <img loading="lazy" decoding="async" src="/images/boutique-interior.jpg" alt="Streams — LA Scenting Model 02">
      </div>
      <div class="reveal rd1">
        <div class="product-label">02</div>
        <span class="s-label">Streams</span>
        <h2 class="s-title" style="margin-bottom: 8px;">Directional Scent<br>for Intimate Environments</h2>
        <p class="s-body" style="margin-bottom: 28px;">For boutique spaces where discretion and beauty are equally non-negotiable. Streams is a standalone sculptural diffuser — designed to be placed, not hidden. Directional diffusion allows distinct olfactory zones within a single space: a retail entrance, a VIP lounge, a hotel corridor, each holding its own atmosphere.</p>
        <div>
          <div class="spec-row">
            <div class="spec-check"></div>
            <p class="s-body">Targeted zone-specific scenting — layer distinct atmospheres across different areas of one space</p>
          </div>
          <div class="spec-row">
            <div class="spec-check"></div>
            <p class="s-body">Architectural sculptural form — a considered object that contributes to the interior rather than interrupting it</p>
          </div>
          <div class="spec-row">
            <div class="spec-check"></div>
            <p class="s-body">App-controlled intensity and scheduling, individually configurable per unit</p>
          </div>
        </div>
        <div style="margin-top: 36px; display: flex; gap: 16px; flex-wrap: wrap;">
          <a href="/contact" class="btn btn-dark">Enquire Now <span style="font-size:1.1em">→</span></a>
          <a href="/contact" class="btn btn-light">Request Brochure</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DEPLOYMENT EXCELLENCE -->
<section class="section-wrap scale-bg">
  <div class="inner" style="max-width: var(--max-w); margin: 0 auto;">
    <div class="reveal" style="margin-bottom: 64px;">
      <span class="s-label" style="color: rgba(201,175,128,0.5);">Deployment Excellence</span>
      <h2 class="s-title-lg" style="color: var(--cream);">Built for the<br>World's Best Spaces</h2>
    </div>
    <div class="grid-3">
      <div class="reveal" style="padding: 40px 32px; border: 1px solid rgba(237,233,223,0.07);">
        <div class="tech-icon">✦</div>
        <h3 style="font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: var(--cream); margin-bottom: 14px;">HVAC Seamless</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.45);">Direct connection to air handling units ensures uniform distribution across multiple zones without visible hardware — the gold standard for hotel groups, airports, and commercial towers.</p>
      </div>
      <div class="reveal rd1" style="padding: 40px 32px; border: 1px solid rgba(237,233,223,0.07);">
        <div class="tech-icon">◎</div>
        <h3 style="font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: var(--cream); margin-bottom: 14px;">Cloud Intelligence</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.45);">Monitor oil levels, schedule intensity, and manage entire global estates from a single dashboard. Real-time diagnostics and remote adjustment — for operators who require precision at scale.</p>
      </div>
      <div class="reveal rd2" style="padding: 40px 32px; border: 1px solid rgba(237,233,223,0.07);">
        <div class="tech-icon">⟡</div>
        <h3 style="font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: var(--cream); margin-bottom: 14px;">Sustainably Pure</h3>
        <p class="s-body" style="color: rgba(237,233,223,0.45);">100% essential oil compounds. Zero heat, zero ozone generation. Healthier air, preserved molecular integrity, and a commitment to environmental responsibility built into every unit we deploy.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-wrap newsletter-bg">
  <div style="max-width: 640px; margin: 0 auto; text-align: center;" class="reveal">
    <span class="s-label" style="color: rgba(201,175,128,0.5);">Ready to Begin</span>
    <h2 style="font-family: var(--font-head); font-size: clamp(1.4rem, 3vw, 2.2rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--cream); margin-bottom: 16px;">Transform Your Atmosphere</h2>
    <p class="s-body" style="color: rgba(237,233,223,0.45); margin-bottom: 40px;">We work with a select number of clients each season. Tell us about your space and we will tell you what is possible.</p>
    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
      <a href="/contact" class="btn btn-sand">Request a Consultation <span style="font-size:1.1em">→</span></a>
    </div>
  </div>
</section>

<Footer />
<script src="/app.js" is:inline></script>
</Base>
